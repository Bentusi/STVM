(* 示例程序 1: Hello World *)
(* 简单的变量声明和赋值 *)

PROGRAM HelloWorld
VAR
    message : STRING := 'Hello, STVM!';
    counter : INT := 0;
    result : REAL;
END_VAR

    (* 打印消息 *)
    counter := 42;
    result := 3.14159;
    
    (* 简单运算 *)
    counter := counter + 1;
    result := result * 2.0;
END_PROGRAM
