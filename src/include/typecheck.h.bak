/**
 * @file typecheck.h
 * @brief ST语言类型检查器
 * 
 * 语义分析和类型检查，验证程序的类型正确性
 */

#ifndef TYPECHECK_H
#define TYPECHECK_H

#include "ast.h"
#include "symtbl.h"
#include "error.h"

// 类型检查器上下文
typedef struct {
    SymbolTable* symtbl;        // 符号表
    ASTNode* current_function;  // 当前函数（用于检查return）
    bool had_error;             // 是否有错误
    ErrorCode error_code;       // 错误码
    char error_msg[256];        // 错误信息
} TypeChecker;

/**
 * @brief 初始化类型检查器
 * @param checker 类型检查器指针
 * @param symtbl 符号表指针
 * @return 错误码
 */
ErrorCode typecheck_init(TypeChecker* checker, SymbolTable* symtbl);

/**
 * @brief 清理类型检查器资源
 * @param checker 类型检查器指针
 */
void typecheck_cleanup(TypeChecker* checker);

/**
 * @brief 检查程序
 * @param checker 类型检查器指针
 * @param program 程序AST节点
 * @return 错误码
 */
ErrorCode typecheck_program(TypeChecker* checker, ASTNode* program);

/**
 * @brief 检查函数声明
 * @param checker 类型检查器指针
 * @param function 函数AST节点
 * @return 错误码
 */
ErrorCode typecheck_function(TypeChecker* checker, ASTNode* function);

/**
 * @brief 检查变量声明
 * @param checker 类型检查器指针
 * @param var_decl 变量声明AST节点
 * @return 错误码
 */
ErrorCode typecheck_var_decl(TypeChecker* checker, ASTNode* var_decl);

/**
 * @brief 检查语句
 * @param checker 类型检查器指针
 * @param stmt 语句AST节点
 * @return 错误码
 */
ErrorCode typecheck_statement(TypeChecker* checker, ASTNode* stmt);

/**
 * @brief 检查表达式并推导类型
 * @param checker 类型检查器指针
 * @param expr 表达式AST节点
 * @return 表达式类型（NULL表示错误）
 */
TypeInfo* typecheck_expression(TypeChecker* checker, ASTNode* expr);

/**
 * @brief 检查赋值兼容性
 * @param checker 类型检查器指针
 * @param target_type 目标类型
 * @param value_type 值类型
 * @return 是否兼容
 */
bool typecheck_assignment_compatible(TypeChecker* checker, 
                                    TypeInfo* target_type, 
                                    TypeInfo* value_type);

/**
 * @brief 检查二元运算符类型
 * @param checker 类型检查器指针
 * @param op 运算符
 * @param left_type 左操作数类型
 * @param right_type 右操作数类型
 * @return 结果类型（NULL表示错误）
 */
TypeInfo* typecheck_binary_op(TypeChecker* checker,
                              BinaryOperator op,
                              TypeInfo* left_type,
                              TypeInfo* right_type);

/**
 * @brief 检查一元运算符类型
 * @param checker 类型检查器指针
 * @param op 运算符
 * @param operand_type 操作数类型
 * @return 结果类型（NULL表示错误）
 */
TypeInfo* typecheck_unary_op(TypeChecker* checker,
                             UnaryOperator op,
                             TypeInfo* operand_type);

/**
 * @brief 检查函数调用
 * @param checker 类型检查器指针
 * @param call 函数调用AST节点
 * @return 返回类型（NULL表示错误）
 */
TypeInfo* typecheck_call(TypeChecker* checker, ASTNode* call);

/**
 * @brief 报告类型错误
 * @param checker 类型检查器指针
 * @param node AST节点
 * @param message 错误信息
 */
void typecheck_error(TypeChecker* checker, ASTNode* node, const char* message);

/**
 * @brief 类型转换（如果需要）
 * @param from_type 源类型
 * @param to_type 目标类型
 * @return 是否可以转换
 */
bool typecheck_can_convert(TypeInfo* from_type, TypeInfo* to_type);

#endif // TYPECHECK_H
